<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageVersion>1.0.0</PackageVersion>
		<OutputType>Library</OutputType>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
		<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
		<PackageReadmeFile>Readme.md</PackageReadmeFile>
		<NeutralLanguage>en-150</NeutralLanguage>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<Authors>ThrashingLaggard</Authors>
		<Company>$(Authors) Industries</Company>
	</PropertyGroup>

	<ItemGroup>
		<Folder Include="Helper\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Localization.Abstractions" Version="10.0.5" />
		<PackageReference Include="Selenium.Support" Version="4.41.0" />
	</ItemGroup>

	<ItemGroup>
		<None Update="Readme.md">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>



</Project>
